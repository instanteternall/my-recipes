{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile"
  },
  "deploy": {
    "startCommand": "java -jar -Dspring.profiles.active=prod app.jar",
    "healthcheckPath": "/api/recipes/hot",
    "restartPolicyType": "ON_FAILURE"
  }
}
